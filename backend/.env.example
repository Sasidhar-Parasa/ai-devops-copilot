# ═══════════════════════════════════════════════════════
#  AI DevOps Copilot — Environment Variables
#  Copy to .env and fill values. Never commit .env.
# ═══════════════════════════════════════════════════════

# ── FREE LLM (choose ONE — Groq recommended) ─────────
# Option 1: Groq FREE — https://console.groq.com
GROQ_API_KEY=gsk_...your_groq_key_here...

# Option 2: Google Gemini FREE — https://aistudio.google.com
GEMINI_API_KEY=AIza...your_gemini_key_here...

# ── GCP Configuration ────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── App Config ───────────────────────────────────────
LOG_LEVEL=INFO
APP_ENV=development
WORKSPACE_DIR=/tmp/copilot-workspace
